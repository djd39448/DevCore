# DevCore — required environment variables.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored
# (CODING_STANDARDS.md dc-06) — never commit real credentials.

# Pinecone — read-only reference for the TrustCore base coding standard.
# Used by the `pinecone` MCP server registered in .mcp.json.
PINECONE_API_KEY=

# Anthropic — the model behind DevCore's agents during the build phase.
ANTHROPIC_API_KEY=
