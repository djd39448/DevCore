{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(gofumpt:*)",
      "Bash(golangci-lint:*)"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'DevCore — current phase (from build_log.md):'; grep -E '^## .*Phase' build_log.md 2>/dev/null | tail -1"
          }
        ]
      }
    ]
  }
}
